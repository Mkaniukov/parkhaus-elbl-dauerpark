# --- Netlify Functions (Submit / E-Mail): diese Variablen in Netlify unter
# Site → Environment variables → Scope „Production“ setzen (nicht nur lokal in .env).
# Ohne MAIL_* oder Resend werden Anträge nur in Supabase gespeichert — keine E-Mail.

# --- Supabase (optional, aber empfohlen) ---
SUPABASE_URL=https://xxxx.supabase.co
# alter Name; alternativ neuer Secret-Key:
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY=

# --- E-Mail: SMTP (Fallback, falls kein Resend) ---
# App-Passwort in Google-Konto erstellen; Wert NUR in Netlify env, nie ins Repo.
# Hinweis Netlify: Viele SMTP-Anbieter blockieren Verbindungen von Cloud-Servern.
# Zuverlässiger: Resend (unten) oder anderer HTTP-API-Versand.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
# true = SSL (465), false = STARTTLS (z. B. Port 587)
MAIL_SECURE=true
MAIL_USER=info@carelbl.at
MAIL_PASSWORD=
# Absender-Anzeige (optional, Default: Parkhaus ELBL <MAIL_USER>)
MAIL_FROM="Parkhaus ELBL <info@carelbl.at>"
NOTIFY_TO=office@parkhaus-elbl.at

# --- Empfohlen für Netlify: Resend (HTTPS, weniger Sperren als SMTP) ---
# Wenn gesetzt, wird Resend VOR SMTP versucht. Domain in Resend verifizieren.
# RESEND_API_KEY=re_...
# NOTIFY_FROM="Parkhaus ELBL <noreply@deine-verifizierte-domain.at>"

# Optional: Contract-PDF als Mail-Anhang (langsamer/Risiko). Standard: keine Zeile gesetzt =
# nur Link zum Google-Doc im HTML (= stabil wie vor der PDF-Anhang-Integration).
# MAIL_INCLUDE_CONTRACT_PDF=true

# Optional: kein Word-Anhang in der Function (nur HTML-Mail), z. B. bei docx-Problemen
# SKIP_WORD_ATTACHMENT=true

# Optional: lokales Frontend
# VITE_SUBMIT_URL=http://localhost:8888/.netlify/functions/submit
