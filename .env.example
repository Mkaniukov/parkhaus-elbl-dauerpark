# --- Supabase (optional, aber empfohlen) ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- E-Mail: SMTP (Google Workspace / Gmail) — bevorzugt ---
# App-Passwort in Google-Konto erstellen; Wert NUR in Netlify env, nie ins Repo.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
# true = SSL (465), false = STARTTLS (z. B. Port 587)
MAIL_SECURE=true
MAIL_USER=info@carelbl.at
MAIL_PASSWORD=
# Absender-Anzeige (optional, Default: Parkhaus ELBL <MAIL_USER>)
MAIL_FROM="Parkhaus ELBL <info@carelbl.at>"
NOTIFY_TO=office@parkhaus-elbl.at

# --- Alternative: Resend (nur wenn kein SMTP) ---
# RESEND_API_KEY=
# NOTIFY_FROM="Parkhaus ELBL <noreply@...>"

# Optional: lokales Frontend
# VITE_SUBMIT_URL=http://localhost:8888/.netlify/functions/submit
